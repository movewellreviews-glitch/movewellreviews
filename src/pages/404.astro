---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Page Not Found">
  <section class="container not-found">
    <h1>404 — Page not found</h1>
    <p>The page you're looking for doesn't exist or the product isn't published yet.</p>
    <a href="/" class="btn-primary">Back to home</a>
  </section>
</BaseLayout>

<style>
  .not-found { padding: 80px 24px; text-align: center; }
  .btn-primary {
    display: inline-block; margin-top: 16px; background: #14532d; color: white;
    padding: 12px 24px; border-radius: 8px; font-weight: 700; text-decoration: none;
  }
</style>
