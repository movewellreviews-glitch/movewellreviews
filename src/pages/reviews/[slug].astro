---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StarRating from '../../components/StarRating.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { SITE, hubForCategory } from '../../consts';

export const prerender = true;

export async function getStaticPaths() {
  const products = await getCollection('products', ({ data }) => data.published);
  return products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const { Content } = await product.render();
const { brand, name, tagline, coverImage, rating, specs, pros, cons, priceNote, testingMethodology, author, publishDate, seo, category } = product.data;
const hub = hubForCategory(category);
const score = rating ? (rating * 2).toFixed(1) : null;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Reviews', item: `${SITE.url}/reviews` },
      { '@type': 'ListItem', position: 3, name: name, item: `${SITE.url}/reviews/${product.slug}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name,
    brand: { '@type': 'Brand', name: brand },
    image: coverImage ? new URL(coverImage, SITE.url).toString() : undefined,
    description: tagline,
    ...(rating
      ? {
          review: {
            '@type': 'Review',
            reviewRating: { '@type': 'Rating', ratingValue: rating, bestRating: '5' },
            author: { '@type': 'Organization', name: author },
          },
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: rating,
            bestRating: '5',
            ratingCount: 1,
          },
        }
      : {}),
  },
];
---
<BaseLayout
  title={seo?.title || `${name} Review`}
  description={seo?.description || tagline || `Our hands-on review of the ${name}.`}
  image={coverImage}
  structuredData={structuredData}
>
  <article class={`container review ac-${hub.accent}`}>
    <div class="cat"><a href={`/best/${hub.slug}`}>{hub.short}</a> · Review</div>

    <header class="review-header">
      <div class="himg">
        <img src={coverImage || '/images/placeholder-product.svg'} alt={name} />
      </div>
      <div class="hinfo">
        <div class="brand">{brand}</div>
        <h1>{name}</h1>
        {tagline && <p class="tagline">{tagline}</p>}
        <div class="scorerow">
          {score && <span class="sc">{score}<small>/10</small></span>}
          {rating ? <StarRating rating={rating} /> : null}
        </div>
        <div class="cta-row">
          <a href={`/go/${product.slug}`} class="buybtn" rel="sponsored nofollow noopener" target="_blank">
            Check current price →
          </a>
        </div>
        {priceNote && <p class="price-note">{priceNote}</p>}
      </div>
    </header>

    <p class="ameta">
      By {author} · Last updated {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>

    {(pros.length > 0 || cons.length > 0) && (
      <section class="pros-cons">
        <div class="pc move">
          <h2>Pros</h2>
          <ul>{pros.map((p) => <li>{p}</li>)}</ul>
        </div>
        <div class="pc rec">
          <h2>Cons</h2>
          <ul>{cons.map((c) => <li>{c}</li>)}</ul>
        </div>
      </section>
    )}

    {specs.length > 0 && (
      <section>
        <h2 class="sech">Specs</h2>
        <div class="tablewrap">
          <table class="specs">
            <tbody>
              {specs.map((s) => (
                <tr><th>{s.label}</th><td>{s.value}</td></tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <section class="content">
      <Content />
    </section>

    {testingMethodology && (
      <section class="methodology">
        <h2>How we tested it</h2>
        <p>{testingMethodology}</p>
      </section>
    )}
  </article>

  <div class="sticky-cta">
    <div class="sticky-cta-inner">
      <div class="sticky-info">
        <img src={coverImage || '/images/placeholder-product.svg'} alt="" />
        <div>
          <div class="sticky-name">{name}</div>
          {rating ? <StarRating rating={rating} /> : null}
        </div>
      </div>
      <a href={`/go/${product.slug}`} class="buybtn sm" rel="sponsored nofollow noopener" target="_blank">
        Check price
      </a>
    </div>
  </div>
</BaseLayout>

<style>
  .review { padding: 50px 24px 90px; max-width: 860px; }
  .cat {
    font-size: 13px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--ac-deep); margin-bottom: 14px;
  }
  .cat a { color: inherit; }
  .cat a:hover { text-decoration: underline; }
  .review-header { display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 10px; }
  .himg {
    width: 280px; height: 280px; flex: none;
    background: var(--paper); border: 1px solid var(--line); border-radius: 16px;
    padding: 16px; display: flex; align-items: center; justify-content: center;
  }
  .himg img { width: 100%; height: 100%; object-fit: contain; }
  .hinfo { flex: 1; min-width: 260px; }
  .brand { font-size: 13px; text-transform: uppercase; color: var(--ink-soft); font-weight: 600; letter-spacing: 0.05em; }
  h1 { font-size: clamp(28px, 4vw, 40px); font-weight: 600; line-height: 1.1; margin: 6px 0 10px; }
  .tagline { color: var(--ink-soft); margin: 0 0 12px; }
  .scorerow { display: flex; align-items: center; gap: 14px; margin-bottom: 18px; }
  .sc { font-family: var(--font-heading); font-weight: 600; font-size: 28px; }
  .sc small { font-size: 14px; color: var(--ink-soft); font-family: var(--font-body); }
  .buybtn {
    display: inline-block; background: var(--ac); color: #fff !important;
    font-weight: 600; padding: 13px 24px; border-radius: 100px;
    text-decoration: none !important; white-space: nowrap;
  }
  .buybtn:hover { background: var(--ac-deep); }
  .buybtn.sm { padding: 10px 18px; font-size: 13.5px; }
  .price-note { font-size: 13px; color: var(--ink-soft); margin: 8px 0 0; }
  .ameta {
    color: var(--ink-soft); font-size: 14px;
    margin: 26px 0; padding-bottom: 26px; border-bottom: 1px solid var(--line);
  }

  .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 8px 0 32px; }
  .pc { border-radius: 16px; padding: 22px 24px; border: 1px solid var(--line); background: var(--paper); }
  .pc.move { background: linear-gradient(160deg, #EAF5EE, #FFFFFF); }
  .pc.rec { background: linear-gradient(160deg, #FBEDE0, #FFFFFF); }
  .pc h2 { font-size: 19px; margin: 0 0 10px; }
  .pc.move h2 { color: var(--move-deep); }
  .pc.rec h2 { color: var(--recover-deep); }
  .pc ul { padding-left: 20px; margin: 0; }
  .pc li { margin-bottom: 8px; font-size: 15px; color: var(--ink-soft); }

  .sech { font-size: 24px; margin: 0 0 14px; }
  .tablewrap { overflow-x: auto; border-radius: 16px; border: 1px solid var(--line); background: var(--paper); margin-bottom: 28px; }
  .specs { width: 100%; border-collapse: collapse; font-size: 14.5px; }
  .specs th, .specs td { text-align: left; padding: 15px 18px; border-bottom: 1px solid var(--line); }
  .specs tr:last-child th, .specs tr:last-child td { border-bottom: none; }
  .specs th { color: var(--ink-soft); font-weight: 600; width: 40%; font-family: var(--font-heading); }

  .content { font-size: 17.5px; line-height: 1.8; color: #26332C; margin: 24px 0; }
  .content :global(h2) { font-size: 28px; font-weight: 600; margin: 34px 0 12px; }
  .content :global(h3) { font-size: 22px; font-weight: 600; margin: 26px 0 10px; }
  .content :global(p) { margin-bottom: 18px; }
  .content :global(img) { max-width: 100%; border-radius: 12px; margin: 12px 0; }
  .content :global(a) { color: var(--move-deep); text-decoration: underline; }
  .content :global(blockquote) {
    border-left: 3px solid var(--recover); padding: 6px 18px; margin: 18px 0;
    color: var(--ink-soft); font-style: italic;
  }

  .methodology {
    background: var(--sage); border: 1px solid var(--line);
    border-radius: 16px; padding: 22px 24px; margin: 24px 0 0;
  }
  .methodology h2 { font-size: 19px; margin: 0 0 8px; }
  .methodology p { margin: 0; color: var(--ink-soft); font-size: 15px; }

  .sticky-cta { display: none; }

  @media (max-width: 560px) {
    .pros-cons { grid-template-columns: 1fr; }
    .himg { width: 100%; height: 240px; }

    .sticky-cta {
      display: block;
      position: fixed;
      left: 0; right: 0; bottom: 0;
      z-index: 200;
      background: var(--paper);
      border-top: 1px solid var(--line);
      box-shadow: 0 -12px 30px -18px rgba(23, 36, 30, 0.4);
      padding: 10px 14px calc(10px + env(safe-area-inset-bottom));
    }
    .sticky-cta-inner { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .sticky-info { display: flex; align-items: center; gap: 10px; min-width: 0; }
    .sticky-info img { width: 38px; height: 38px; object-fit: contain; background: var(--bg); border-radius: 8px; flex-shrink: 0; }
    .sticky-name { font-size: 12.5px; font-weight: 600; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .review { padding-bottom: 100px; }
  }
</style>
