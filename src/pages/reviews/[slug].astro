---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StarRating from '../../components/StarRating.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { SITE } from '../../consts';

export const prerender = true;

export async function getStaticPaths() {
  const products = await getCollection('products', ({ data }) => data.published);
  return products.map((product) => ({ params: { slug: product.slug }, props: { product } }));
}

interface Props {
  product: CollectionEntry<'products'>;
}

const { product } = Astro.props;
const { Content } = await product.render();
const { brand, name, tagline, coverImage, rating, specs, pros, cons, priceNote, testingMethodology, author, publishDate, seo } = product.data;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Reviews', item: `${SITE.url}/reviews` },
      { '@type': 'ListItem', position: 3, name: name, item: `${SITE.url}/reviews/${product.slug}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name,
    brand: { '@type': 'Brand', name: brand },
    image: coverImage ? new URL(coverImage, SITE.url).toString() : undefined,
    description: tagline,
    ...(rating
      ? {
          review: {
            '@type': 'Review',
            reviewRating: { '@type': 'Rating', ratingValue: rating, bestRating: '5' },
            author: { '@type': 'Organization', name: author },
          },
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: rating,
            bestRating: '5',
            ratingCount: 1,
          },
        }
      : {}),
  },
];
---
<BaseLayout
  title={seo?.title || `${name} Review`}
  description={seo?.description || tagline || `Our hands-on review of the ${name}.`}
  image={coverImage}
  structuredData={structuredData}
>
  <article class="container review">
    <nav class="breadcrumb"><a href="/reviews">Reviews</a> / {name}</nav>

    <header class="review-header">
      <img src={coverImage || '/images/placeholder-product.svg'} alt={name} class="hero-img" />
      <div>
        <div class="brand">{brand}</div>
        <h1>{name}</h1>
        {tagline && <p class="tagline">{tagline}</p>}
        {rating ? <StarRating rating={rating} /> : null}
        <div class="cta-row">
          <a href={`/go/${product.slug}`} class="btn-primary" rel="sponsored nofollow noopener" target="_blank">
            Check current price
          </a>
        </div>
        {priceNote && <p class="price-note">{priceNote}</p>}
      </div>
    </header>

    <AffiliateDisclosure />

    {(pros.length > 0 || cons.length > 0) && (
      <section class="pros-cons">
        <div>
          <h2>Pros</h2>
          <ul>{pros.map((p) => <li>{p}</li>)}</ul>
        </div>
        <div>
          <h2>Cons</h2>
          <ul>{cons.map((c) => <li>{c}</li>)}</ul>
        </div>
      </section>
    )}

    {specs.length > 0 && (
      <section>
        <h2>Specs</h2>
        <table class="specs">
          <tbody>
            {specs.map((s) => (
              <tr><th>{s.label}</th><td>{s.value}</td></tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    <section class="body">
      <Content />
    </section>

    {testingMethodology && (
      <section class="methodology">
        <h2>How we tested it</h2>
        <p>{testingMethodology}</p>
      </section>
    )}

    <p class="updated">
      Last updated: {publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
  </article>
</BaseLayout>

<style>
  .review { padding: 30px 24px 70px; max-width: 820px; }
  .breadcrumb { font-size: 0.8rem; color: #888; margin-bottom: 20px; }
  .breadcrumb a { color: #888; }
  .review-header { display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 10px; }
  .hero-img { width: 260px; height: 260px; object-fit: contain; background: #f6f7f6; border-radius: 12px; padding: 20px; }
  .review-header > div { flex: 1; min-width: 260px; }
  .brand { font-size: 0.75rem; text-transform: uppercase; color: #888; font-weight: 700; }
  .tagline { color: #555; }
  .cta-row { margin: 14px 0 6px; }
  .btn-primary {
    display: inline-block; background: var(--color-primary); color: white; padding: 12px 24px;
    border-radius: 8px; font-weight: 700; text-decoration: none;
  }
  .price-note { font-size: 0.78rem; color: #999; }
  .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 28px 0; }
  .pros-cons ul { padding-left: 20px; margin: 8px 0; }
  .specs { width: 100%; border-collapse: collapse; margin: 14px 0 28px; }
  .specs th, .specs td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #eee; font-size: 0.88rem; }
  .specs th { color: #666; font-weight: 600; width: 40%; }
  .body { margin: 24px 0; font-size: 0.98rem; }
  .body :global(img) { border-radius: 10px; margin: 20px 0 6px; }
  .body :global(h2) { margin-top: 32px; }
  .methodology { background: #f7f8f7; border-radius: 10px; padding: 18px 20px; margin: 24px 0; }
  .updated { font-size: 0.78rem; color: #999; }
  @media (max-width: 560px) {
    .pros-cons { grid-template-columns: 1fr; }
  }
</style>
