---
import BaseLayout from '../../layouts/BaseLayout.astro';
import StarRating from '../../components/StarRating.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { supabase } from '../../lib/supabase';
import { SITE } from '../../consts';

const { slug } = Astro.params;

const { data: product } = await supabase
  .from('products')
  .select('*, reviews(*)')
  .eq('slug', slug)
  .eq('is_published', true)
  .maybeSingle();

if (!product) {
  return Astro.redirect('/404');
}

const review = Array.isArray(product.reviews) ? product.reviews[0] : product.reviews;
const specs = product.specs || {};
const pros = product.pros || [];
const cons = product.cons || [];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: SITE.url },
      { '@type': 'ListItem', position: 2, name: 'Reviews', item: `${SITE.url}/reviews` },
      { '@type': 'ListItem', position: 3, name: product.name, item: `${SITE.url}/reviews/${product.slug}` },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'Product',
    name: product.name,
    brand: { '@type': 'Brand', name: product.brand },
    image: product.image_url ? new URL(product.image_url, SITE.url).toString() : undefined,
    description: product.tagline,
    ...(product.rating
      ? {
          review: {
            '@type': 'Review',
            reviewRating: { '@type': 'Rating', ratingValue: product.rating, bestRating: '5' },
            author: { '@type': 'Organization', name: review?.author || 'MoveWell Reviews Team' },
          },
          aggregateRating: {
            '@type': 'AggregateRating',
            ratingValue: product.rating,
            bestRating: '5',
            ratingCount: 1,
          },
        }
      : {}),
  },
];
---
<BaseLayout
  title={`${product.name} Review`}
  description={product.tagline || `Our hands-on review of the ${product.name}.`}
  image={product.image_url}
  structuredData={structuredData}
>
  <article class="container review">
    <nav class="breadcrumb"><a href="/reviews">Reviews</a> / {product.name}</nav>

    <header class="review-header">
      <img src={product.image_url || '/images/placeholder-product.svg'} alt={product.name} class="hero-img" />
      <div>
        <div class="brand">{product.brand}</div>
        <h1>{product.name}</h1>
        {product.tagline && <p class="tagline">{product.tagline}</p>}
        {product.rating ? <StarRating rating={product.rating} /> : null}
        <div class="cta-row">
          <a href={`/go/${product.affiliate_slug}`} class="btn-primary" rel="sponsored nofollow noopener" target="_blank">
            Check current price
          </a>
        </div>
        {product.price_note && <p class="price-note">{product.price_note}</p>}
      </div>
    </header>

    <AffiliateDisclosure />

    {(pros.length > 0 || cons.length > 0) && (
      <section class="pros-cons">
        <div>
          <h2>Pros</h2>
          <ul>{pros.map((p: string) => <li>{p}</li>)}</ul>
        </div>
        <div>
          <h2>Cons</h2>
          <ul>{cons.map((c: string) => <li>{c}</li>)}</ul>
        </div>
      </section>
    )}

    {Object.keys(specs).length > 0 && (
      <section>
        <h2>Specs</h2>
        <table class="specs">
          <tbody>
            {Object.entries(specs).map(([k, v]) => (
              <tr><th>{k.replaceAll('_', ' ')}</th><td>{v as string}</td></tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {review?.body_html && (
      <section class="body" set:html={review.body_html} />
    )}

    {review?.testing_methodology && (
      <section class="methodology">
        <h2>How we tested it</h2>
        <p>{review.testing_methodology}</p>
      </section>
    )}

    <p class="updated">
      Last updated: {new Date(review?.last_updated || product.updated_at).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
  </article>
</BaseLayout>

<style>
  .review { padding: 30px 24px 70px; max-width: 820px; }
  .breadcrumb { font-size: 0.8rem; color: #888; margin-bottom: 20px; }
  .breadcrumb a { color: #888; }
  .review-header { display: flex; gap: 28px; flex-wrap: wrap; margin-bottom: 10px; }
  .hero-img { width: 260px; height: 260px; object-fit: contain; background: #f6f7f6; border-radius: 12px; padding: 20px; }
  .review-header > div { flex: 1; min-width: 260px; }
  .brand { font-size: 0.75rem; text-transform: uppercase; color: #888; font-weight: 700; }
  .tagline { color: #555; }
  .cta-row { margin: 14px 0 6px; }
  .btn-primary {
    display: inline-block; background: #14532d; color: white; padding: 12px 24px;
    border-radius: 8px; font-weight: 700; text-decoration: none;
  }
  .price-note { font-size: 0.78rem; color: #999; }
  .pros-cons { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin: 28px 0; }
  .pros-cons ul { padding-left: 20px; margin: 8px 0; }
  .specs { width: 100%; border-collapse: collapse; margin: 14px 0 28px; }
  .specs th, .specs td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #eee; font-size: 0.88rem; }
  .specs th { color: #666; font-weight: 600; text-transform: capitalize; width: 40%; }
  .body { margin: 24px 0; font-size: 0.98rem; }
  .methodology { background: #f7f8f7; border-radius: 10px; padding: 18px 20px; margin: 24px 0; }
  .updated { font-size: 0.78rem; color: #999; }
  @media (max-width: 560px) {
    .pros-cons { grid-template-columns: 1fr; }
  }
</style>
