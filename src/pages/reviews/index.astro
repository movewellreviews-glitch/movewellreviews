---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const allProducts = await getCollection('products', ({ data }) => data.published);
const products = allProducts.sort((a, b) => b.data.rating - a.data.rating);
---
<BaseLayout title="All Reviews" description="Every product we've tested and reviewed, walking pads and recovery gear alike.">
  <div class="page-hero">
    <h1>All Reviews</h1>
    <p>Every product we've bought and tested ourselves.</p>
  </div>

  <section class="container catwrap">
    <div class="catgrid">
      {products.map((p) => <ProductCard product={p} />)}
      {products.length === 0 && (
        <p class="empty">No published reviews yet. Add products at <a href="/admin">/admin</a>.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .catwrap { padding: 26px 24px 80px; }
  .catgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .empty { color: var(--ink-soft); }
  .empty a { text-decoration: underline; }
  @media (max-width: 900px) { .catgrid { grid-template-columns: 1fr; } }
</style>
