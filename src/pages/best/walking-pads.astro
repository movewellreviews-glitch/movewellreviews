---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProductCard from '../../components/ProductCard.astro';
import ComparisonTable from '../../components/ComparisonTable.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../../consts';

export const prerender = true;

const allProducts = await getCollection(
  'products',
  ({ data }) => data.published && data.category === 'walking-pads'
);
const products = allProducts.sort((a, b) => b.data.rating - a.data.rating);

const specLabels = ['Speed range', 'Weight capacity', 'Noise level', 'Dimensions'];

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  itemListElement: products.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    url: `${SITE.url}/reviews/${p.slug}`,
    name: p.data.name,
  })),
};
---
<BaseLayout
  title="Best Walking Pads (Tested & Ranked)"
  description="We tested under-desk treadmills and walking pads for noise, stability, and build quality. Here are our top picks."
  structuredData={structuredData}
>
  <div class="container cathero move">
    <span class="tag">Move</span>
    <h1>Walking pads</h1>
    <p>
      We put each walking pad through the same treadmill test: noise at 2 mph next to a laptop mic,
      wobble under load, folding mechanism durability, and app/remote reliability over two weeks of daily use.
    </p>
  </div>

  <div class="container catwrap">
    <div class="catgrid">
      {products.map((p) => <ProductCard product={p} />)}
      {products.length === 0 && (
        <p class="empty">No published walking pads yet — publish some at <a href="/admin">/admin</a>.</p>
      )}
    </div>
  </div>

  {products.length > 1 && (
    <section class="container cmpsec">
      <h2>Side-by-side comparison</h2>
      <ComparisonTable products={products} specLabels={specLabels} />
    </section>
  )}
</BaseLayout>

<style>
  .cathero { padding: 50px 24px 6px; }
  .cathero .tag {
    display: inline-block; font-size: 12.5px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    padding: 5px 12px; border-radius: 100px; color: #fff;
    margin-bottom: 16px; background: var(--move);
  }
  .cathero h1 { font-size: clamp(32px, 4.8vw, 50px); font-weight: 600; margin: 0; }
  .cathero p { color: var(--ink-soft); font-size: 17px; margin: 12px 0 0; max-width: 56ch; }
  .catwrap { padding: 30px 24px 60px; }
  .catgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; }
  .empty { color: var(--ink-soft); }
  .empty a { text-decoration: underline; }
  .cmpsec { padding-bottom: 80px; }
  .cmpsec h2 { font-size: clamp(24px, 3vw, 32px); }
  @media (max-width: 900px) { .catgrid { grid-template-columns: 1fr; } }
</style>
