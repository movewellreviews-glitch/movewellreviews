---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { CATEGORY_LABELS } from '../consts';

export const prerender = true;

const allProducts = await getCollection('products', ({ data }) => data.published);
const products = allProducts.sort((a, b) => b.data.rating - a.data.rating);

const groups = new Map<string, CollectionEntry<'products'>[]>();
for (const p of products) {
  const catLabel = CATEGORY_LABELS[p.data.category] ?? p.data.category;
  if (!groups.has(catLabel)) groups.set(catLabel, []);
  groups.get(catLabel)!.push(p);
}

function topSpecLabels(items: CollectionEntry<'products'>[]) {
  const labels = new Set<string>();
  for (const p of items) for (const s of p.data.specs) labels.add(s.label);
  return [...labels].slice(0, 4);
}
---
<BaseLayout title="Compare Products" description="Side-by-side comparison of every walking pad and recovery product we've reviewed.">
  <section class="container header-block">
    <h1>Compare</h1>
    <p>Every product we've reviewed, side by side, grouped by category.</p>
    <AffiliateDisclosure compact />
  </section>

  {[...groups.entries()].map(([catName, items]) => (
    <section class="container block">
      <h2>{catName}</h2>
      <ComparisonTable products={items} specLabels={topSpecLabels(items)} />
    </section>
  ))}

  {products.length === 0 && (
    <section class="container">
      <p class="empty">No published products yet — publish some at <a href="/admin">/admin</a>.</p>
    </section>
  )}
</BaseLayout>

<style>
  .header-block { padding: 40px 24px 10px; }
  .empty { color: #888; }
</style>
