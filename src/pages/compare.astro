---
import BaseLayout from '../layouts/BaseLayout.astro';
import ComparisonTable from '../components/ComparisonTable.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import { supabase } from '../lib/supabase';

const { data: categories } = await supabase.from('categories').select('slug,name').order('name');

const { data: products } = await supabase
  .from('products')
  .select('slug,brand,name,image_url,rating,affiliate_slug,specs,categories(slug,name)')
  .eq('is_published', true)
  .order('rating', { ascending: false });

const byCategory = new Map<string, any[]>();
for (const p of products ?? []) {
  const cat = (p as any).categories?.name ?? 'Other';
  if (!byCategory.has(cat)) byCategory.set(cat, []);
  byCategory.get(cat)!.push(p);
}

const specKeysByCategory: Record<string, Array<{ key: string; label: string }>> = {
  'Walking Pads': [
    { key: 'speed_range', label: 'Speed range' },
    { key: 'weight_capacity', label: 'Weight capacity' },
    { key: 'noise_level', label: 'Noise level' },
  ],
};
---
<BaseLayout title="Compare Products" description="Side-by-side comparison of every walking pad and recovery product we've reviewed.">
  <section class="container header-block">
    <h1>Compare</h1>
    <p>Every product we've reviewed, side by side, grouped by category.</p>
    <AffiliateDisclosure compact />
  </section>

  {[...byCategory.entries()].map(([catName, items]) => (
    <section class="container block">
      <h2>{catName}</h2>
      <ComparisonTable
        products={items}
        specKeys={specKeysByCategory[catName] ?? [{ key: 'weight_capacity', label: 'Key spec' }]}
      />
    </section>
  ))}

  {(!products || products.length === 0) && (
    <section class="container">
      <p class="empty">No published products yet — publish some in Supabase to populate this page.</p>
    </section>
  )}
</BaseLayout>

<style>
  .header-block { padding: 40px 24px 10px; }
  .empty { color: #888; }
</style>
