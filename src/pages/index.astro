---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductRow from '../components/ProductRow.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';
import { HUBS } from '../consts';

export const prerender = true;

const allProducts = await getCollection('products', ({ data }) => data.published);

// Build a "Top 5" list for each hub that actually has products.
const hubLists = HUBS.map((hub) => ({
  hub,
  items: allProducts
    .filter((p) => hub.categories.includes(p.data.category))
    .sort((a, b) => b.data.rating - a.data.rating)
    .slice(0, 5),
})).filter((h) => h.items.length > 0);

// Featured "pick of the month": highest-rated product overall.
const featured = [...allProducts].sort((a, b) => b.data.rating - a.data.rating)[0] ?? null;
const featBars = featured
  ? [
      { label: 'Performance', w: Math.min(96, Math.round(featured.data.rating * 20) - 2) },
      { label: 'Build quality', w: Math.min(92, Math.round(featured.data.rating * 20) - 6) },
      { label: 'Value', w: Math.min(84, Math.round(featured.data.rating * 20) - 14) },
    ]
  : [];

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---
<BaseLayout title="Walking Pads, Recovery, Home Gym & Wearables — Honestly Reviewed">
  <section class="hero"><div class="container hero-grid">
    <div>
      <span class="eyebrow">Independent, hands-on reviews</span>
      <h1 class="hero-h1">Move <span class="g">more</span>. Recover <span class="o">better</span>. Right from home.</h1>
      <p class="lede">We buy and test walking pads, recovery tools, home-gym gear, and fitness wearables for people who live and work at home — then tell you what's actually worth buying.</p>
      <div class="btns">
        <a href="#picks" class="btn btn-primary">See our top picks →</a>
        <a href="/editorial-policy" class="btn btn-secondary">How we test</a>
      </div>
      <div class="trust">
        <span>★ Tested in real homes</span>
        <span>· No pay-for-play reviews</span>
        <span>· FTC-compliant disclosures</span>
      </div>
    </div>
    {featured && (
      <div class="feature">
        <div class="fimg">
          <img src={featured.data.coverImage || '/images/placeholder-product.svg'} alt={featured.data.name} />
        </div>
        <div class="cap">Pick of the month</div>
        <h3>{featured.data.name}</h3>
        {featBars.map((b) => (
          <div class="row"><span>{b.label}</span><span class="bar"><i style={`width:${b.w}%`}></i></span></div>
        ))}
        <a href={`/reviews/${featured.slug}`} class="flink">Read the full review →</a>
      </div>
    )}
  </div></section>

  <section class="pillars"><div class="container pill-grid">
    {HUBS.map((hub) => (
      <a class={`pillar ac-${hub.accent}`} href={`/best/${hub.slug}`}>
        <span class="tag">{hub.tag}</span>
        <h3>{hub.short}</h3>
        <p>{hub.blurb}</p>
        <span class="lnk">Browse {hub.short.toLowerCase()} →</span>
      </a>
    ))}
  </div></section>

  <section class="blk" id="picks"><div class="container">
    <div class="head">
      <span class="k">Tested &amp; ranked</span>
      <h2 class="title">Our top picks by category</h2>
      <p>Best-rated gear in each category, ranked from hands-on testing — not press releases.</p>
    </div>

    {hubLists.length === 0 && (
      <p class="empty">No products published yet. Add reviews in <code>src/content/products/</code> and set <code>published: true</code>.</p>
    )}

    {hubLists.map(({ hub, items }) => (
      <div class={`toplist-wrap ac-${hub.accent}`}>
        <div class="listhead">
          <h3 class="listh">{hub.short} — Top {items.length}</h3>
          <a href={`/best/${hub.slug}`} class="seeall">See all →</a>
        </div>
        <div class="toplist">
          {items.map((p, i) => <ProductRow product={p} rank={i + 1} />)}
        </div>
      </div>
    ))}
  </div></section>

  <section class="blk method" id="test"><div class="container">
    <div class="head">
      <span class="k">The method</span>
      <h2 class="title">How we test</h2>
      <p>Why our scores mean something — nothing gets rated from a spec sheet.</p>
    </div>
    <div class="steps">
      <div class="step">
        <div class="ic">1</div>
        <h3>Real weeks, real homes</h3>
        <p>Every product lives in a working home for weeks before it earns a score — not a 20-minute unboxing.</p>
      </div>
      <div class="step">
        <div class="ic">2</div>
        <h3>We measure, not guess</h3>
        <p>Noise, stall force, battery, heart-rate accuracy, footprint — we check the numbers ourselves.</p>
      </div>
      <div class="step">
        <div class="ic">3</div>
        <h3>Brands don't buy scores</h3>
        <p>Commissions keep the lights on, never the ratings. A weak product stays a weak product here.</p>
      </div>
    </div>
    <a href="/editorial-policy" class="btn btn-secondary" style="margin-top:30px">Read our full editorial policy →</a>
  </div></section>

  {posts.length > 0 && (
    <section class="blk"><div class="container">
      <div class="head">
        <span class="k">From the blog</span>
        <h2 class="title">Guides &amp; reviews</h2>
        <p>Honest, hands-on advice for moving more and recovering better.</p>
      </div>
      <div class="bloglist">
        {posts.map((post) => (
          <a class="bpost" href={`/blog/${post.slug}`}>
            <div class="cov">
              <img src={post.data.coverImage || '/images/placeholder-blog.svg'} alt={post.data.title} loading="lazy" />
            </div>
            <div class="bp-b">
              <span class="cat">Guide</span>
              <h3>{post.data.title}</h3>
              <p>{post.data.excerpt}</p>
              <span class="meta">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
            </div>
          </a>
        ))}
      </div>
      <div style="margin-top:26px">
        <a href="/blog" class="btn btn-secondary">Read all articles →</a>
      </div>
    </div></section>
  )}

  <section class="container">
    <Newsletter />
  </section>
</BaseLayout>

<style>
  .hero { padding: 66px 0 50px; }
  .hero-grid { display: grid; grid-template-columns: 1fr 1.15fr; gap: 48px; align-items: center; }
  .hero-h1 {
    font-size: clamp(38px, 5.4vw, 66px);
    font-weight: 600;
    line-height: 1.04;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .hero-h1 .g { color: var(--move); }
  .hero-h1 .o { color: var(--recover-deep); }
  .lede { font-size: clamp(17px, 1.9vw, 21px); color: var(--ink-soft); margin: 24px 0 30px; max-width: 46ch; }
  .btns { display: flex; gap: 14px; flex-wrap: wrap; }
  .trust { margin-top: 24px; display: flex; flex-wrap: wrap; gap: 4px 10px; font-size: 13.5px; color: var(--ink-soft); font-weight: 500; }
  .trust span:first-child { color: var(--amber-deep); }

  .feature {
    background: var(--paper);
    border-radius: 22px;
    padding: 22px;
    box-shadow: 0 20px 50px -22px rgba(23, 36, 30, 0.28);
    border: 1px solid var(--line);
  }
  .feature .fimg {
    border-radius: 16px; overflow: hidden; background: var(--sage);
    aspect-ratio: 16/11; margin-bottom: 18px;
    display: flex; align-items: center; justify-content: center;
  }
  .feature .fimg img { width: 100%; height: 100%; object-fit: contain; }
  .feature .cap {
    font-size: 12.5px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--recover-deep); margin-bottom: 6px;
  }
  .feature h3 { font-size: 23px; font-weight: 600; margin: 0 0 14px; }
  .feature .row {
    display: flex; justify-content: space-between; align-items: center;
    font-size: 14px; padding: 9px 0; border-top: 1px solid var(--line);
  }
  .bar { height: 6px; border-radius: 4px; background: var(--sage); overflow: hidden; width: 120px; }
  .bar i { display: block; height: 100%; background: var(--recover); }
  .flink { display: inline-block; margin-top: 14px; font-weight: 600; font-size: 14.5px; color: var(--move-deep); }
  .flink:hover { text-decoration: underline; }

  .pillars { padding: 16px 0 36px; }
  .pill-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .pillar {
    border-radius: 20px; padding: 26px; border: 1px solid var(--line);
    transition: transform 0.16s, box-shadow 0.16s; display: block;
    background: linear-gradient(165deg, var(--ac-soft), #F7F8F4);
  }
  .pillar:hover { transform: translateY(-4px); box-shadow: 0 22px 40px -28px rgba(23,36,30,0.4); }
  .pillar .tag {
    display: inline-block; font-size: 12px; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.06em;
    padding: 5px 12px; border-radius: 100px; color: #fff; margin-bottom: 14px;
    background: var(--ac);
  }
  .pillar h3 { font-size: 22px; font-weight: 600; margin: 0 0 8px; }
  .pillar p { color: var(--ink-soft); font-size: 14.5px; margin: 0 0 16px; line-height: 1.55; }
  .pillar .lnk { font-weight: 600; font-size: 14.5px; color: var(--ac-deep); }

  .toplist-wrap { margin-bottom: 40px; }
  .listhead { display: flex; align-items: baseline; justify-content: space-between; margin-bottom: 16px; gap: 12px; }
  .listh { font-size: 22px; font-weight: 600; margin: 0; color: var(--ac-deep); }
  .seeall { font-weight: 600; font-size: 14.5px; color: var(--ac-deep); white-space: nowrap; }
  .seeall:hover { text-decoration: underline; }
  .toplist { display: flex; flex-direction: column; gap: 14px; }
  .empty { color: var(--ink-soft); background: var(--paper); border: 1px solid var(--line); border-radius: 14px; padding: 20px 24px; }
  .empty code { background: var(--sage); padding: 1px 6px; border-radius: 5px; font-size: 13px; }

  .method { background: var(--paper); border-top: 1px solid var(--line); border-bottom: 1px solid var(--line); }
  .steps { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .step { background: var(--bg); border: 1px solid var(--line); border-radius: 16px; padding: 28px; }
  .step .ic {
    width: 46px; height: 46px; border-radius: 12px;
    display: grid; place-items: center; margin-bottom: 16px;
    font-family: var(--font-heading); font-weight: 700; font-size: 20px; color: #fff;
  }
  .step:nth-child(1) .ic { background: var(--move); }
  .step:nth-child(2) .ic { background: var(--recover); }
  .step:nth-child(3) .ic { background: var(--strength); }
  .step h3 { font-size: 20px; font-weight: 600; margin: 0 0 8px; }
  .step p { color: var(--ink-soft); font-size: 14.5px; margin: 0; }

  .bloglist { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; }
  .bpost {
    background: var(--paper); border: 1px solid var(--line); border-radius: 16px;
    overflow: hidden; transition: transform 0.15s, box-shadow 0.15s;
    display: flex; flex-direction: column;
  }
  .bpost:hover { transform: translateY(-5px); box-shadow: 0 24px 44px -26px rgba(23, 36, 30, 0.35); }
  .bpost .cov { aspect-ratio: 16/9; background: var(--sage); }
  .bpost .cov img { width: 100%; height: 100%; object-fit: cover; }
  .bpost .bp-b { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .bpost .cat {
    font-size: 12px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; margin-bottom: 10px; color: var(--move-deep);
  }
  .bpost h3 { font-size: 20px; font-weight: 600; margin: 0 0 8px; line-height: 1.2; }
  .bpost p { color: var(--ink-soft); font-size: 14px; flex: 1; margin: 0; }
  .bpost .meta { margin-top: 14px; font-size: 12.5px; color: var(--ink-soft); }

  @media (max-width: 1000px) {
    .pill-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 40px; }
    .steps { grid-template-columns: 1fr; }
    .bloglist { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 640px) {
    .pill-grid { grid-template-columns: 1fr; }
    .bloglist { grid-template-columns: 1fr; }
  }
</style>
