---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProductCard from '../components/ProductCard.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';
import { SITE } from '../consts';

export const prerender = true;

const RECOVERY_CATEGORIES = ['massage-guns', 'compression', 'foam-rollers'];

const allProducts = await getCollection('products', ({ data }) => data.published);
const walkingPads = allProducts
  .filter((p) => p.data.category === 'walking-pads')
  .sort((a, b) => b.data.rating - a.data.rating)
  .slice(0, 3);
const recovery = allProducts
  .filter((p) => RECOVERY_CATEGORIES.includes(p.data.category))
  .sort((a, b) => b.data.rating - a.data.rating)
  .slice(0, 3);

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 3);
---
<BaseLayout title="Home">
  <section class="hero container">
    <h1>Honest, hands-on reviews of walking pads &amp; recovery gear</h1>
    <p class="lede">{SITE.tagline} We buy, test, and compare so you don't have to guess.</p>
    <div class="hero-ctas">
      <a href="/best/walking-pads" class="btn-primary">Best Walking Pads →</a>
      <a href="/best/recovery-tools" class="btn-secondary">Best Recovery Tools →</a>
    </div>
  </section>

  <section class="container">
    <AffiliateDisclosure compact />
  </section>

  <section class="container block">
    <div class="block-head">
      <h2>Top-rated walking pads</h2>
      <a href="/best/walking-pads">See all →</a>
    </div>
    <div class="grid">
      {(walkingPads ?? []).map((p) => <ProductCard product={p} />)}
      {walkingPads.length === 0 && (
        <p class="empty">No products published yet — add some at <a href="/admin">/admin</a>.</p>
      )}
    </div>
  </section>

  <section class="container block">
    <div class="block-head">
      <h2>Top-rated recovery tools</h2>
      <a href="/best/recovery-tools">See all →</a>
    </div>
    <div class="grid">
      {(recovery ?? []).map((p) => <ProductCard product={p} />)}
      {recovery.length === 0 && (
        <p class="empty">No products published yet — add some at <a href="/admin">/admin</a>.</p>
      )}
    </div>
  </section>

  {posts && posts.length > 0 && (
    <section class="container block">
      <div class="block-head">
        <h2>Latest from the blog</h2>
        <a href="/blog">See all →</a>
      </div>
      <div class="grid posts">
        {posts.map((post) => (
          <a class="post-card" href={`/blog/${post.slug}`}>
            <img src={post.data.coverImage || '/images/placeholder-blog.svg'} alt={post.data.title} />
            <h3>{post.data.title}</h3>
            <p>{post.data.excerpt}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="container">
    <Newsletter />
  </section>
</BaseLayout>

<style>
  .hero { padding: 56px 24px 24px; text-align: center; }
  .hero h1 { font-size: 2.3rem; max-width: 780px; margin: 0 auto 14px; }
  .lede { font-size: 1.1rem; color: #555; max-width: 620px; margin: 0 auto 24px; }
  .hero-ctas { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }
  .btn-primary, .btn-secondary {
    padding: 12px 22px; border-radius: 8px; font-weight: 700; text-decoration: none; font-size: 0.95rem;
  }
  .btn-primary { background: var(--color-primary); color: white; }
  .btn-secondary { background: #f1f3f1; color: #16241a; }
  .block { margin: 44px auto; }
  .block-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 18px; }
  .block-head h2 { font-size: 1.4rem; margin: 0; }
  .block-head a { font-size: 0.88rem; font-weight: 600; color: var(--color-primary); text-decoration: none; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; }
  .empty { color: #888; font-size: 0.9rem; }
  .post-card { text-decoration: none; color: inherit; border: 1px solid #eee; border-radius: 12px; overflow: hidden; }
  .post-card img { height: 160px; object-fit: cover; background: #f6f7f6; }
  .post-card h3 { font-size: 1rem; margin: 14px 14px 6px; }
  .post-card p { font-size: 0.85rem; color: #666; margin: 0 14px 14px; }
</style>
