---
// /go/:slug -> a prerendered redirect page that forwards to the product's real
// affiliate URL. Keeping the destination out of the linked HTML (a "cloaked"
// affiliate link) is a common, TOS-compliant pattern for Amazon Associates and
// most networks, and lets you swap a destination in one place.
//
// This is a STATIC site, so each redirect is generated at build time as its own
// HTML file that does an instant client-side redirect (meta refresh + JS), with
// a visible fallback link for the rare no-JS visitor.
export const prerender = true;

import { getCollection } from 'astro:content';
import { SITE } from '../../consts';

export async function getStaticPaths() {
  const products = await getCollection('products', ({ data }) => data.published);
  return products.map((product) => ({
    params: { slug: product.slug },
    props: { url: product.data.affiliateUrl, name: product.data.name },
  }));
}

const { url, name } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Redirecting… | {SITE.name}</title>
    <link rel="canonical" href={url} />
    <meta http-equiv="refresh" content={`0; url=${url}`} />
    <style>
      body { font-family: system-ui, sans-serif; background: #F4F5F0; color: #17241E;
        display: grid; place-items: center; min-height: 100vh; margin: 0; text-align: center; padding: 24px; }
      a { color: #0C6B3F; }
    </style>
  </head>
  <body>
    <p>
      Taking you to the retailer for <strong>{name}</strong>…<br />
      If you are not redirected, <a href={url} rel="sponsored nofollow noopener">click here to continue</a>.
    </p>
    <script is:inline define:vars={{ url }}>
      window.location.replace(url);
    </script>
  </body>
</html>
