---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---
<BaseLayout title="Blog" description="Buying guides and how-to articles about walking pads and recovery gear.">
  <div class="container blog-hero">
    <h1>The MoveWell Blog</h1>
    <p>Honest guides on walking pads, massage guns, and recovering from desk life.</p>
  </div>

  <div class="container">
    <div class="bloglist">
      {posts.map((post) => (
        <a class="bpost" href={`/blog/${post.slug}`}>
          <div class="cov">
            <img src={post.data.coverImage || '/images/placeholder-blog.svg'} alt={post.data.title} loading="lazy" />
          </div>
          <div class="bp-b">
            <span class="cat move">Guides</span>
            <h3>{post.data.title}</h3>
            <p>{post.data.excerpt}</p>
            <span class="meta">{post.data.publishDate.toLocaleDateString('en-US', { month: 'short', year: 'numeric' })}</span>
          </div>
        </a>
      ))}
      {posts.length === 0 && (
        <p class="empty">No published guides yet — write one at <a href="/admin">/admin</a>.</p>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .blog-hero { padding: 56px 24px 20px; }
  .blog-hero h1 { font-size: clamp(34px, 5vw, 54px); font-weight: 600; margin: 0; }
  .blog-hero p { color: var(--ink-soft); font-size: 17px; margin: 12px 0 0; max-width: 56ch; }
  .bloglist { display: grid; grid-template-columns: repeat(3, 1fr); gap: 26px; padding: 26px 0 80px; }
  .bpost {
    background: var(--paper); border: 1px solid var(--line); border-radius: 16px;
    overflow: hidden; transition: transform 0.15s, box-shadow 0.15s;
    display: flex; flex-direction: column;
  }
  .bpost:hover { transform: translateY(-5px); box-shadow: 0 24px 44px -26px rgba(23, 36, 30, 0.35); }
  .bpost .cov { aspect-ratio: 16/9; background: var(--sage); }
  .bpost .cov img { width: 100%; height: 100%; object-fit: cover; }
  .bpost .bp-b { padding: 20px; flex: 1; display: flex; flex-direction: column; }
  .bpost .cat {
    font-size: 12px; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; margin-bottom: 10px; color: var(--move-deep);
  }
  .bpost h3 { font-size: 20px; font-weight: 600; margin: 0 0 8px; line-height: 1.2; }
  .bpost p { color: var(--ink-soft); font-size: 14px; flex: 1; margin: 0; }
  .bpost .meta { margin-top: 14px; font-size: 12.5px; color: var(--ink-soft); }
  .empty { color: var(--ink-soft); }
  .empty a { text-decoration: underline; }
  @media (max-width: 900px) { .bloglist { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .bloglist { grid-template-columns: 1fr; } }
</style>
