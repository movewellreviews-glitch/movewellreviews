---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export const prerender = true;

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---
<BaseLayout title="Blog" description="Buying guides and how-to articles about walking pads and recovery gear.">
  <section class="container header-block">
    <h1>Blog</h1>
    <p>Deeper dives to help you choose the right gear for your space, budget, and routine.</p>
  </section>

  <section class="container">
    <div class="grid">
      {posts.map((post) => (
        <a class="post-card" href={`/blog/${post.slug}`}>
          <img src={post.data.coverImage || '/images/placeholder-blog.svg'} alt={post.data.title} />
          <div class="body">
            <h2>{post.data.title}</h2>
            <p>{post.data.excerpt}</p>
            <span class="date">{post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
          </div>
        </a>
      ))}
      {posts.length === 0 && (
        <p class="empty">No published guides yet — write one at <a href="/admin">/admin</a>.</p>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .header-block { padding: 40px 24px 10px; }
  .header-block p { color: #666; }
  .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; margin: 24px auto 60px; }
  .post-card { text-decoration: none; color: inherit; border: 1px solid #eee; border-radius: 12px; overflow: hidden; display: block; }
  .post-card img { height: 170px; object-fit: cover; background: #f6f7f6; }
  .post-card .body { padding: 14px; }
  .post-card h2 { font-size: 1.05rem; margin: 0 0 6px; }
  .post-card p { font-size: 0.86rem; color: #666; margin: 0 0 10px; }
  .date { font-size: 0.75rem; color: #999; }
  .empty { color: #888; }
</style>
