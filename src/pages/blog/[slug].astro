---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import { SITE } from '../../consts';

export const prerender = true;

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await post.render();

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  image: post.data.coverImage ? new URL(post.data.coverImage, SITE.url).toString() : undefined,
  datePublished: post.data.publishDate.toISOString(),
  author: { '@type': 'Organization', name: post.data.author },
};
---
<BaseLayout
  title={post.data.title}
  description={post.data.excerpt}
  image={post.data.coverImage}
  structuredData={structuredData}
>
  <article class="container post">
    <nav class="breadcrumb"><a href="/blog">Blog</a> / {post.data.title}</nav>
    <h1>{post.data.title}</h1>
    <p class="meta">
      By {post.data.author} · {post.data.publishDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
    </p>
    {post.data.coverImage && <img class="cover" src={post.data.coverImage} alt={post.data.title} />}
    <AffiliateDisclosure compact />
    <div class="body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post { padding: 30px 24px 70px; max-width: 760px; }
  .breadcrumb { font-size: 0.8rem; color: #888; margin-bottom: 14px; }
  .breadcrumb a { color: #888; }
  .meta { color: #888; font-size: 0.85rem; }
  .cover { border-radius: 12px; margin: 16px 0; }
  .body { font-size: 1rem; margin-top: 20px; }
  .body :global(h2) { margin-top: 32px; }
  .body :global(img) { border-radius: 10px; margin: 20px 0 6px; }
  .body :global(figure) { margin: 20px 0; }
  .body :global(figcaption) { font-size: 0.82rem; color: #888; margin-top: 6px; }
  .body :global(em) { font-size: 0.82rem; color: #888; }
</style>
