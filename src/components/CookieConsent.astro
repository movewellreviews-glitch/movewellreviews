---
// Lightweight, no-cookie-until-consent banner for CCPA/CPRA visitors.
// Only relevant if you add ad-tech/analytics that share data with third parties.
// Privacy-first analytics (e.g. Plausible) don't require this at all.
---
<div id="cookie-consent" class="cookie-banner">
  <div class="card">
    <p>
      We use minimal analytics to understand traffic. We do not sell your personal information.
      See our <a href="/privacy-policy">Privacy Policy</a>.
    </p>
    <div class="actions">
      <button id="cookie-decline" class="btn-ghost">Decline non-essential</button>
      <button id="cookie-accept" class="btn-primary">Accept</button>
    </div>
  </div>
</div>

<style>
  .cookie-banner {
    position: fixed;
    left: 0;
    right: 0;
    bottom: 16px;
    z-index: 300;
    display: none;
    justify-content: center;
    padding: 0 16px;
    pointer-events: none;
  }
  .cookie-banner.is-visible {
    display: flex;
  }
  .card {
    pointer-events: auto;
    width: 100%;
    max-width: 620px;
    background: var(--color-ink);
    color: #eee;
    padding: 18px 22px;
    border-radius: var(--radius-md);
    display: flex;
    flex-wrap: wrap;
    gap: 14px;
    align-items: center;
    justify-content: space-between;
    box-shadow: var(--shadow-lg);
    font-family: var(--font-body);
  }
  .card p { margin: 0; font-size: 0.85rem; flex: 1; min-width: 220px; }
  .card a { color: var(--color-primary-light); }
  .actions { display: flex; gap: 10px; flex-wrap: wrap; }
  .btn-primary, .btn-ghost {
    padding: 9px 18px;
    border-radius: var(--radius-sm);
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    border: 1px solid transparent;
    white-space: nowrap;
  }
  .btn-primary { background: var(--color-primary); color: white; }
  .btn-primary:hover { background: var(--color-primary-dark); }
  .btn-ghost { background: transparent; color: #ccc; border-color: #555; }

  @media (max-width: 520px) {
    .cookie-banner { bottom: 0; padding: 0; }
    .card { border-radius: 12px 12px 0 0; max-width: 100%; justify-content: center; text-align: center; }
    .card p { flex: 1 1 100%; }
    .actions { flex: 1 1 100%; justify-content: center; }
  }
</style>

<script>
  const KEY = 'movewell_consent';
  const banner = document.getElementById('cookie-consent');
  const stored = localStorage.getItem(KEY);
  if (!stored && banner) banner.classList.add('is-visible');

  document.getElementById('cookie-accept')?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'accepted');
    if (banner) banner.classList.remove('is-visible');
    document.dispatchEvent(new CustomEvent('consent-changed', { detail: 'accepted' }));
  });
  document.getElementById('cookie-decline')?.addEventListener('click', () => {
    localStorage.setItem(KEY, 'declined');
    if (banner) banner.classList.remove('is-visible');
    document.dispatchEvent(new CustomEvent('consent-changed', { detail: 'declined' }));
  });
</script>
