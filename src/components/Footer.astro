---
import { SITE, HUBS, FOOTER_SITE, FOOTER_LEGAL } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="fgrid">
      <div>
        <div class="logo">
          <span class="dot" aria-hidden="true"><i></i><i></i><i></i></span>
          MoveWell
        </div>
        <p class="about">Independent, hands-on reviews of the gear that helps you move more and recover better — walking pads, recovery tools, home-gym equipment, and wearables.</p>
      </div>
      <div>
        <h4>Categories</h4>
        <ul>
          {HUBS.map((h) => <li><a href={`/best/${h.slug}`}>{h.short}</a></li>)}
        </ul>
      </div>
      <div>
        <h4>Site</h4>
        <ul>
          {FOOTER_SITE.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>
      <div>
        <h4>Legal</h4>
        <ul>
          {FOOTER_LEGAL.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
        </ul>
      </div>
    </div>
    <div class="legal">
      <b>Affiliate disclosure:</b> {SITE.name} is reader-supported. When you buy through links on our site, we may earn an affiliate commission at no extra cost to you. This never influences our ratings. <b>As an Amazon Associate we earn from qualifying purchases.</b> <a href="/affiliate-disclosure">Learn more</a>.<br />
      <b>Health disclaimer:</b> Content is for general information only and is not medical advice. Talk to a physician before starting a new exercise, strength, or recovery routine. See our <a href="/disclaimer">full disclaimer</a>. &nbsp;·&nbsp; © {year} {SITE.name} · <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a> · Not affiliated with Amazon.com or any brand reviewed on this site.
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--paper);
    border-top: 1px solid var(--line);
    padding: 54px 0 32px;
    margin-top: 60px;
  }
  .fgrid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 36px;
  }
  .logo {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
  }
  .logo .dot { display: flex; gap: 3px; align-items: flex-end; }
  .logo .dot i { display: block; width: 5px; border-radius: 3px; background: var(--move); }
  .logo .dot i:nth-child(1) { height: 11px; }
  .logo .dot i:nth-child(2) { height: 17px; }
  .logo .dot i:nth-child(3) { height: 9px; background: var(--recover); }
  .about { color: var(--ink-soft); font-size: 14.5px; max-width: 32ch; margin-top: 12px; }
  h4 { font-size: 15px; font-weight: 600; margin: 0 0 14px; }
  ul { list-style: none; margin: 0; padding: 0; }
  li { margin-bottom: 9px; }
  li a { color: var(--ink-soft); font-size: 14.5px; }
  li a:hover { color: var(--move-deep); }
  .legal {
    border-top: 1px solid var(--line);
    padding-top: 22px;
    color: var(--ink-soft);
    font-size: 12.5px;
    line-height: 1.7;
  }
  .legal b { color: var(--ink); }
  .legal a { text-decoration: underline; }
  @media (max-width: 900px) { .fgrid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .fgrid { grid-template-columns: 1fr; } }
</style>
