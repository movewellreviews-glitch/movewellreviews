---
import { SITE } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="container">
    <div class="fgrid">
      <div>
        <div class="logo">
          <span class="dot" aria-hidden="true"><i></i><i></i><i></i></span>
          MoveWell
        </div>
        <p class="about">Independent, hands-on reviews of walking pads and recovery gear for people who live and work at home.</p>
      </div>
      <div>
        <h4>Reviews</h4>
        <ul>
          <li><a href="/best/walking-pads">Walking Pads</a></li>
          <li><a href="/best/recovery-tools">Recovery</a></li>
          <li><a href="/reviews">All Reviews</a></li>
          <li><a href="/compare">Compare</a></li>
        </ul>
      </div>
      <div>
        <h4>Site</h4>
        <ul>
          <li><a href="/about">About Us</a></li>
          <li><a href="/blog">Blog</a></li>
          <li><a href="/contact">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4>Legal</h4>
        <ul>
          <li><a href="/affiliate-disclosure">Affiliate Disclosure</a></li>
          <li><a href="/privacy-policy">Privacy Policy</a></li>
          <li><a href="/terms">Terms of Use</a></li>
        </ul>
      </div>
    </div>
    <div class="legal">
      <b>Affiliate disclosure:</b> {SITE.name} is reader-supported. When you buy through links on our site, we may earn an affiliate commission at no extra cost to you. This never influences our ratings.<br />
      <b>Health disclaimer:</b> Content is for general information only and is not medical advice. Talk to a physician before starting a new exercise or recovery routine. &nbsp;·&nbsp; © {year} {SITE.name} · <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a> · Not affiliated with Amazon.com or any brand reviewed on this site.
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--paper);
    border-top: 1px solid var(--line);
    padding: 54px 0 32px;
    margin-top: 60px;
  }
  .fgrid {
    display: grid;
    grid-template-columns: 1.7fr 1fr 1fr 1fr;
    gap: 32px;
    margin-bottom: 36px;
  }
  .logo {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 24px;
    letter-spacing: -0.01em;
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
  }
  .logo .dot { display: flex; gap: 3px; align-items: flex-end; }
  .logo .dot i { display: block; width: 5px; border-radius: 3px; background: var(--move); }
  .logo .dot i:nth-child(1) { height: 11px; }
  .logo .dot i:nth-child(2) { height: 17px; }
  .logo .dot i:nth-child(3) { height: 9px; background: var(--recover); }
  .about { color: var(--ink-soft); font-size: 14.5px; max-width: 32ch; margin-top: 12px; }
  h4 { font-size: 15px; font-weight: 600; margin: 0 0 14px; }
  ul { list-style: none; margin: 0; padding: 0; }
  li { margin-bottom: 9px; }
  li a { color: var(--ink-soft); font-size: 14.5px; }
  li a:hover { color: var(--move-deep); }
  .legal {
    border-top: 1px solid var(--line);
    padding-top: 22px;
    color: var(--ink-soft);
    font-size: 12.5px;
    line-height: 1.7;
  }
  .legal b { color: var(--ink); }
  .legal a { text-decoration: underline; }
  @media (max-width: 900px) { .fgrid { grid-template-columns: 1fr 1fr; } }
  @media (max-width: 640px) { .fgrid { grid-template-columns: 1fr; } }
</style>
