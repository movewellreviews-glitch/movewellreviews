---
import { SITE, FOOTER_LINKS } from '../consts';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="inner">
    <div class="col">
      <div class="brand">{SITE.name}</div>
      <p>{SITE.description}</p>
    </div>
    <div class="col">
      <h4>Legal</h4>
      {FOOTER_LINKS.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
    <div class="col">
      <h4>Contact</h4>
      <a href={`mailto:${SITE.contactEmail}`}>{SITE.contactEmail}</a>
    </div>
  </div>
  <div class="bottom">
    &copy; {year} {SITE.name}. All rights reserved. Not affiliated with Amazon.com or any brand reviewed on this site.
  </div>
</footer>

<style>
  .site-footer {
    background: #14231a;
    color: #cfd8d2;
    margin-top: 60px;
    padding: 44px 24px 20px;
  }
  .inner {
    max-width: 1160px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: 30px;
  }
  .brand { font-weight: 800; color: white; font-size: 1.1rem; margin-bottom: 8px; }
  .col p, .col a { font-size: 0.85rem; color: #b7c2bb; line-height: 1.6; }
  .col a { display: block; text-decoration: none; margin-bottom: 8px; }
  .col a:hover { color: #7fd1ae; }
  .col h4 { color: white; font-size: 0.9rem; margin-bottom: 12px; }
  .bottom {
    max-width: 1160px;
    margin: 30px auto 0;
    padding-top: 18px;
    border-top: 1px solid #2a3a30;
    font-size: 0.78rem;
    color: #8b9790;
  }
  @media (max-width: 640px) {
    .inner { grid-template-columns: 1fr; }
  }
</style>
