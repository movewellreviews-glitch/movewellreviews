---
import { DISCLOSURE_SHORT } from '../consts';

interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---
<div class:list={["disclosure", { compact }]}>
  <p>
    <strong>Affiliate Disclosure:</strong> {DISCLOSURE_SHORT}
    {' '}<a href="/affiliate-disclosure">Learn more</a>.
  </p>
</div>

<style>
  .disclosure {
    background: #fff8e6;
    border: 1px solid #f0d78c;
    border-radius: 8px;
    padding: 12px 16px;
    font-size: 0.85rem;
    color: #5c4a1a;
    line-height: 1.5;
    margin: 16px 0;
  }
  .disclosure.compact {
    padding: 8px 12px;
    font-size: 0.78rem;
  }
  .disclosure a {
    color: #8a6d1f;
    font-weight: 600;
  }
</style>
