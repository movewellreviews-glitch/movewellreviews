---
import type { CollectionEntry } from 'astro:content';
import StarRating from './StarRating.astro';

interface Props {
  products: CollectionEntry<'products'>[];
  specLabels: string[];
}
const { products, specLabels } = Astro.props;

function specValue(product: CollectionEntry<'products'>, label: string) {
  return product.data.specs.find((s) => s.label === label)?.value ?? '—';
}
---
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Rating</th>
        {specLabels.map((label) => <th>{label}</th>)}
        <th></th>
      </tr>
    </thead>
    <tbody>
      {products.map((p) => (
        <tr>
          <td class="product-cell">
            <img src={p.data.coverImage || '/images/placeholder-product.svg'} alt={p.data.name} />
            <div>
              <div class="brand">{p.data.brand}</div>
              <a href={`/reviews/${p.slug}`}>{p.data.name}</a>
            </div>
          </td>
          <td>{p.data.rating ? <StarRating rating={p.data.rating} /> : '—'}</td>
          {specLabels.map((label) => <td>{specValue(p, label)}</td>)}
          <td>
            <a href={`/go/${p.slug}`} class="price" rel="sponsored nofollow noopener" target="_blank">
              Check price →
            </a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-wrap {
    overflow-x: auto;
    margin: 24px 0;
    border-radius: 16px;
    border: 1px solid #cfdbcd;
    background: var(--paper);
  }
  table { border-collapse: collapse; width: 100%; min-width: 640px; font-size: 14.5px; }
  th, td { padding: 15px 18px; text-align: left; border-bottom: 1px solid var(--line); white-space: nowrap; }
  thead th {
    font-family: var(--font-heading);
    font-weight: 600;
    font-size: 15px;
    background: #F0F4EE;
    color: var(--ink);
    text-transform: none;
    letter-spacing: 0;
  }
  tbody tr:last-child td { border-bottom: none; }
  .product-cell { display: flex; align-items: center; gap: 12px; white-space: normal; min-width: 220px; }
  .product-cell img { width: 48px; height: 48px; object-fit: contain; background: #fff; border: 1px solid var(--line); border-radius: 8px; padding: 4px; }
  .brand { font-size: 11px; color: var(--ink-soft); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
  .product-cell a { color: var(--ink); font-weight: 600; font-family: var(--font-heading); }
  .product-cell a:hover { color: var(--move-deep); }
  .price {
    display: inline-block; background: var(--amber); color: var(--ink);
    font-weight: 700; font-size: 13px; padding: 9px 16px; border-radius: 100px;
  }
  .price:hover { background: var(--amber-deep); }
</style>
