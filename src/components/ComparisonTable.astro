---
import type { CollectionEntry } from 'astro:content';
import StarRating from './StarRating.astro';

interface Props {
  products: CollectionEntry<'products'>[];
  specLabels: string[];
}
const { products, specLabels } = Astro.props;

function specValue(product: CollectionEntry<'products'>, label: string) {
  return product.data.specs.find((s) => s.label === label)?.value ?? '—';
}
---
<div class="table-wrap">
  <table>
    <thead>
      <tr>
        <th>Product</th>
        <th>Rating</th>
        {specLabels.map((label) => <th>{label}</th>)}
        <th></th>
      </tr>
    </thead>
    <tbody>
      {products.map((p) => (
        <tr>
          <td class="product-cell">
            <img src={p.data.coverImage || '/images/placeholder-product.svg'} alt={p.data.name} />
            <div>
              <div class="brand">{p.data.brand}</div>
              <a href={`/reviews/${p.slug}`}>{p.data.name}</a>
            </div>
          </td>
          <td>{p.data.rating ? <StarRating rating={p.data.rating} /> : '—'}</td>
          {specLabels.map((label) => <td>{specValue(p, label)}</td>)}
          <td>
            <a href={`/go/${p.slug}`} class="btn-primary" rel="sponsored nofollow noopener" target="_blank">
              Check price
            </a>
          </td>
        </tr>
      ))}
    </tbody>
  </table>
</div>

<style>
  .table-wrap { overflow-x: auto; margin: 24px 0; border: 1px solid #eee; border-radius: 10px; }
  table { border-collapse: collapse; width: 100%; min-width: 640px; font-size: 0.88rem; }
  th, td { padding: 12px 14px; text-align: left; border-bottom: 1px solid #eee; white-space: nowrap; }
  thead th { background: #f7f8f7; font-weight: 700; color: #444; }
  .product-cell { display: flex; align-items: center; gap: 10px; white-space: normal; min-width: 220px; }
  .product-cell img { width: 48px; height: 48px; object-fit: contain; background: #f6f7f6; border-radius: 6px; }
  .brand { font-size: 0.7rem; color: #888; font-weight: 700; text-transform: uppercase; }
  .product-cell a { color: #16241a; font-weight: 600; text-decoration: none; }
  .btn-primary {
    display: inline-block; background: var(--color-primary); color: white;
    padding: 7px 14px; border-radius: 6px; font-weight: 700; text-decoration: none; font-size: 0.82rem;
  }
</style>
