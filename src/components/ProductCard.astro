---
import type { CollectionEntry } from 'astro:content';
import StarRating from './StarRating.astro';
import { accentForCategory } from '../consts';

interface Props {
  product: CollectionEntry<'products'>;
}
const { product } = Astro.props;
const { brand, name, tagline, coverImage, rating, bestFor, priceNote, category } = product.data;
const accent = accentForCategory(category);
const score = rating ? (rating * 2).toFixed(1) : null;
---
<article class={`card ac-${accent}`}>
  <a href={`/reviews/${product.slug}`} class="pimg">
    <img src={coverImage || '/images/placeholder-product.svg'} alt={name} loading="lazy" />
  </a>
  <div class="cap">
    {bestFor ? <span class="badge">{bestFor}</span> : <span class="brand">{brand}</span>}
    {score && <span class="sc">{score}<small>/10</small></span>}
  </div>
  <div class="b">
    <h3><a href={`/reviews/${product.slug}`}>{name}</a></h3>
    {rating ? <div class="strow"><StarRating rating={rating} /></div> : null}
    {priceNote && <div class="pr">{priceNote}</div>}
    {tagline && <p class="take">{tagline}</p>}
    <div class="ft">
      <a href={`/reviews/${product.slug}`} class="read">Read review</a>
      <a
        href={`/go/${product.slug}`}
        class="price"
        rel="sponsored nofollow noopener"
        target="_blank"
      >
        Check price →
      </a>
    </div>
  </div>
</article>

<style>
  .card {
    background: var(--paper);
    border-radius: 18px;
    border: 1px solid var(--line);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.15s, box-shadow 0.15s;
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 24px 44px -26px rgba(23, 36, 30, 0.35);
  }
  .pimg { aspect-ratio: 4/3; background: #fff; position: relative; padding: 8px; display: block; }
  .pimg img { width: 100%; height: 100%; object-fit: contain; }
  .cap { padding: 16px 20px 0; display: flex; justify-content: space-between; align-items: center; gap: 10px; }
  .badge {
    font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em;
    padding: 6px 12px; border-radius: 100px; color: #fff; background: var(--ac);
  }
  .brand { font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--ink-soft); }
  .sc { font-family: var(--font-heading); font-weight: 600; font-size: 19px; }
  .sc small { font-size: 12px; color: var(--ink-soft); font-family: var(--font-body); }
  .b { padding: 12px 20px 20px; flex: 1; display: flex; flex-direction: column; }
  h3 { font-size: 22px; font-weight: 600; margin: 0 0 4px; }
  h3 a { color: inherit; }
  h3 a:hover { color: var(--ac-deep); }
  .strow { margin-bottom: 6px; }
  .pr { font-size: 14px; font-weight: 600; color: var(--ink-soft); margin-bottom: 8px; }
  .take { color: var(--ink-soft); font-size: 15.5px; margin: 0 0 18px; }
  .ft { margin-top: auto; display: flex; gap: 10px; }
  .ft a {
    flex: 1; text-align: center; font-weight: 600; font-size: 14px;
    padding: 12px; border-radius: 100px;
  }
  .read { border: 1.5px solid var(--line); color: var(--ink); }
  .read:hover { border-color: var(--ink); }
  .price { background: var(--amber); color: var(--ink); font-weight: 700; }
  .price:hover { background: var(--amber-deep); }
</style>
