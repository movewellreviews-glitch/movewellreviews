---
import type { CollectionEntry } from 'astro:content';
import StarRating from './StarRating.astro';

interface Props {
  product: CollectionEntry<'products'>;
}
const { product } = Astro.props;
const { brand, name, tagline, coverImage, rating, bestFor, priceNote } = product.data;
---
<article class="product-card">
  {bestFor && <div class="badge">{bestFor}</div>}
  <a href={`/reviews/${product.slug}`} class="img-link">
    <img src={coverImage || '/images/placeholder-product.svg'} alt={name} loading="lazy" />
  </a>
  <div class="body">
    <div class="brand">{brand}</div>
    <h3><a href={`/reviews/${product.slug}`}>{name}</a></h3>
    {tagline && <p class="tagline">{tagline}</p>}
    {rating ? <StarRating rating={rating} /> : null}
    <div class="cta-row">
      <a href={`/reviews/${product.slug}`} class="btn-secondary">Read review</a>
      <a
        href={`/go/${product.slug}`}
        class="btn-primary"
        rel="sponsored nofollow noopener"
        target="_blank"
      >
        Check price
      </a>
    </div>
    {priceNote && <p class="price-note">{priceNote}</p>}
  </div>
</article>

<style>
  .product-card {
    background: white;
    border: 1px solid #eee;
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .product-card:hover { box-shadow: 0 10px 24px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .badge {
    position: absolute; top: 10px; left: 10px;
    background: #14532d; color: white;
    font-size: 0.7rem; font-weight: 700;
    padding: 4px 10px; border-radius: 999px;
    z-index: 2;
  }
  .img-link { display: block; background: #f6f7f6; }
  .img-link img { width: 100%; height: 190px; object-fit: contain; padding: 16px; }
  .body { padding: 16px; display: flex; flex-direction: column; gap: 6px; }
  .brand { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.04em; color: #888; font-weight: 700; }
  h3 { font-size: 1.02rem; margin: 0; line-height: 1.35; }
  h3 a { color: #16241a; text-decoration: none; }
  h3 a:hover { color: #14532d; }
  .tagline { font-size: 0.85rem; color: #666; margin: 0; }
  .cta-row { display: flex; gap: 8px; margin-top: 10px; }
  .btn-primary, .btn-secondary {
    flex: 1; text-align: center; padding: 9px 10px;
    border-radius: 7px; font-size: 0.85rem; font-weight: 700;
    text-decoration: none;
  }
  .btn-primary { background: #14532d; color: white; }
  .btn-primary:hover { background: #0f3f22; }
  .btn-secondary { background: #f1f3f1; color: #16241a; }
  .btn-secondary:hover { background: #e5e8e5; }
  .price-note { font-size: 0.72rem; color: #999; margin: 2px 0 0; }
</style>
