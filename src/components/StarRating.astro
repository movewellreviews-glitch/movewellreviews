---
interface Props {
  rating: number; // 0-5
}
const { rating } = Astro.props;
const full = Math.round(rating);
---
<span class="stars" aria-label={`Rated ${rating} out of 5`}>
  {Array.from({ length: 5 }).map((_, i) => (
    <span class={`star${i < full ? ' on' : ''}`} aria-hidden="true">★</span>
  ))}
  <span class="num">{rating.toFixed(1)}</span>
</span>

<style>
  .stars { display: inline-flex; gap: 1px; line-height: 1; align-items: center; }
  .star { color: #dcdcd6; font-size: 14px; }
  .star.on { color: #F0A72E; }
  .num { color: var(--ink-soft); margin-left: 6px; font-size: 13.5px; font-weight: 600; }
</style>
