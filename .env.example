# Copy this file to .env for local dev (`npm run dev`).
# In Netlify, set the same keys under Site settings > Environment variables.

# Public (safe to expose to the browser) — used by src/lib/supabase.js for
# read-only queries against tables protected by "public read published" RLS policies.
PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Server-only (Netlify Functions) — grants full read/write, bypassing RLS.
# NEVER prefix these with PUBLIC_ and never commit real values.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
